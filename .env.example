# NF QueryGPT Environment Variables
# Keys loaded from system env - fill in if running locally

# SQLite
DB_PATH=data/nf_buildathon.db

# Pinecone
PINECONE_API_KEY=""
PINECONE_INDEX_NAME="nikahforever"
EMBEDDING_MODEL="llama-text-embed-v2"

# Gemini (OpenAI-compatible via langchain-google-genai)
GEMINI_API_KEY=""
GEMINI_MODELS=gemini-3.1-flash-lite-preview,gemini-3.5-flash,gemini-1.5-flash,gemini-1.5-flash-001,gemini-1.5-pro,gemini-1.5-pro-001,gemini-1.5-flash-002,gemini-1.5-flash-latest

# App
CORS_ORIGINS=http://localhost:8501
